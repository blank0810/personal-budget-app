{
	"mcpServers": {
		"shadcn": {
			"command": "npx",
			"args": ["shadcn@latest", "mcp"]
		},
		"github": {
			"command": "npx",
			"args": ["@modelcontextprotocol/server-github"],
			"env": {
				"GITHUB_TOKEN": "${GITHUB_TOKEN}"
			}
		},
		"playwright": {
			"command": "npx",
			"args": ["@playwright/mcp@0.0.75", "--headless"]
		}
	}
}
